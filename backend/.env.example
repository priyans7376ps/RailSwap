# Flask
FLASK_APP=app.py
FLASK_ENV=development

# Security
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railswap

# JWT expirations
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000

# File uploads
UPLOAD_FOLDER=uploads/tickets
MAX_CONTENT_LENGTH_BYTES=5242880

# Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-admin-password

# RapidAPI Credentials
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=indian-railway-irctc.p.rapidapi.com
RAPIDAPI_BASE_URL=https://indian-railway-irctc.p.rapidapi.com
