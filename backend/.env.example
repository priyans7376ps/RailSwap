# Flask
FLASK_APP=app.py
FLASK_ENV=development

# Security
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret

# Database (PostgreSQL)
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railswap
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railswap

# JWT expirations
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# CORS
# When using cookies for auth refresh, set explicit origins (no '*')
CORS_ORIGINS=http://localhost:5173

# File uploads
UPLOAD_FOLDER=uploads/tickets
MAX_CONTENT_LENGTH_BYTES=5242880

# Admin
DEFAULT_ADMIN_EMAIL=singh876580@gmail.com
DEFAULT_ADMIN_PASSWORD=Singh@2004
